config.json
config.local.json
.env
.env.*

# ---- logs ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- caches ----
.cache/
.electron-builder-cache/
.eslintcache

# ---- editors / OS ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
